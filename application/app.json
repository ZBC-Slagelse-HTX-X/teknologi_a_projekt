{
  "expo": {
    "name": "Subscription Pilot",
    "slug": "subscription-pilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/full_red.png",
    "scheme": "subscription_pilot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/full_red.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jep1x.application"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/full_red.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jep1x.application",
      "permissions": [
        "android.permission.PACKAGE_USAGE_STATS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/red_rounded.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76bdec58-8151-4f59-895f-00fee1d4088d"
      }
    },
    "owner": "jep1x"
  }
}
